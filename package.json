{
  "name": "search-github-repositories",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build",
    "start": "next start",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:browser": "vitest --config=vitest.browser.config.ts",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "type-check": "tsc --noEmit",
    "type-check:files": "tsc-files",
    "prepare": "husky install"
  },
  "dependencies": {
    "@yamada-ui/react": "^2.2.0",
    "lucide-react": "^1.11.0",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser-playwright": "^4.1.5",
    "@yamada-ui/cli": "^2.1.5",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "tsc-files": "^1.1.4",
    "typescript": "^5",
    "vitest": "^4.1.5",
    "vitest-browser-react": "^2.2.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "oxfmt",
      "oxlint --fix",
      "tsc-files"
    ]
  },
  "volta": {
    "node": "24.15.0"
  }
}
